# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (NEVER commit these — they contain secrets)
.env
.env.local
.env.*.local
.env.development
.env.production
# .env.example IS committed (it's the template, no real values)
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# ====== Shoresh / Payload ======

# Local SQLite database (used only in dev — production runs on Neon Postgres)
shoresh-dev.db
shoresh-dev.db-*

# Payload local media uploads (production uses Vercel Blob, local dev uses this folder)
/media/
/public/media/

# Playwright screenshots captured by scripts/screenshot.mjs
/tmp/

# Payload-generated TypeScript types (regenerated on every boot)
/src/payload-types.ts

.vercel
