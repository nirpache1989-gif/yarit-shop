# Shoresh — environment variables template
# Copy this file to `.env.local` and fill in real values for local dev.
# See docs/ENVIRONMENT.md for the full setup guide.

# ═══ Payload CMS ════════════════════════════════════════════════
# 32+ byte random string — signs JWT cookies for the admin login.
# Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# NEVER commit the real value. NEVER reuse between dev and prod.
PAYLOAD_SECRET=

# ═══ Database ═══════════════════════════════════════════════════
# Payload picks the adapter based on the URI shape:
#
#   Local dev (SQLite, zero config, single file):
#     DATABASE_URI=file:./shoresh-dev.db
#
#   Production (Neon Postgres — sign up at https://neon.tech):
#     DATABASE_URI=postgresql://user:password@ep-xxx.neon.tech/neondb?sslmode=require
#
DATABASE_URI=file:./shoresh-dev.db

# ═══ Public site URL ═══════════════════════════════════════════
# Used for: absolute URLs in emails, OpenGraph tags, success redirects.
#   dev: http://localhost:3000
#   prod: https://yourdomain.co.il
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ═══ Media storage (production only) ═══════════════════════════
# Vercel Blob token — if set, Payload uploads go to Vercel Blob
# instead of the local `./media` folder. On Vercel, this is
# auto-injected when you add a Blob store to the project. For local
# dev, leave empty — uploads stay in ./media which is gitignored.
# BLOB_READ_WRITE_TOKEN=

# ═══ Payment provider (Phase D) ════════════════════════════════
# Factory switch: 'mock' (default, dev) or 'meshulam' (production, stub)
# PAYMENT_PROVIDER=mock
#
# Meshulam credentials — only needed when PAYMENT_PROVIDER=meshulam
# MESHULAM_API_KEY=
# MESHULAM_USER_ID=
# MESHULAM_PAGE_CODE=
# MESHULAM_WEBHOOK_SECRET=

# ═══ Email provider (Phase D) ══════════════════════════════════
# Factory switch: 'mock' (default, dev — logs to console) or 'resend' (production, stub)
# EMAIL_PROVIDER=mock
#
# Resend credentials — only needed when EMAIL_PROVIDER=resend
# RESEND_API_KEY=
# RESEND_FROM_EMAIL=no-reply@shoresh.example
# ADMIN_NOTIFICATION_EMAIL=yarit@example.com
