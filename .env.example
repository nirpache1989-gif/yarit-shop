# Shoresh — environment variables template
# Copy this file to `.env.local` and fill in real values for local dev.
# See docs/ENVIRONMENT.md for the full setup guide.
#
# DO NOT commit `.env.local` (it's gitignored).
# DO NOT reuse secrets between dev and prod.

# ═══ Payload CMS ════════════════════════════════════════════════
# 32+ byte random string — signs JWT cookies for the admin login
# AND the checkout success HMAC token. Generate with:
#     node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# In prod this MUST be set — the app hard-fails at boot if it's
# missing in a production-like environment.
PAYLOAD_SECRET=

# ═══ Database ═══════════════════════════════════════════════════
# Payload picks the adapter based on the URI shape:
#
#   Local dev (SQLite, zero config, single file):
#     DATABASE_URI=file:./shoresh-dev.db
#     (or leave unset — Payload falls back to this automatically)
#
#   Production (Neon Postgres — sign up at https://neon.tech):
#     DATABASE_URI=postgresql://user:password@ep-xxx.neon.tech/neondb?sslmode=require
#
# Leave unset in `.env.local` unless you specifically need to point
# local dev at a Postgres branch. Unset = SQLite at ./shoresh-dev.db.
# DATABASE_URI=

# ═══ Public site URL ═══════════════════════════════════════════
# Server-trusted source for payment redirects + email absolute
# URLs + OpenGraph tags. The checkout API deliberately ignores
# any `siteUrl` the client sends and uses this env var instead.
#   dev:  http://localhost:3000
#   prod: https://yarit-shop.vercel.app   (or custom domain)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ═══ Media storage (production only) ═══════════════════════════
# Vercel Blob token — if set, Payload uploads go to Vercel Blob
# instead of the local `./media` folder. On Vercel, this is
# auto-injected when you add a Blob store to the project. For local
# dev, leave empty — uploads stay in ./public/media which is
# gitignored.
# BLOB_READ_WRITE_TOKEN=

# ═══ Payment provider ══════════════════════════════════════════
# Factory switch — pick one of: 'mock' (default) | 'meshulam'
# PAYMENT_PROVIDER=mock
#
# ─── Meshulam credentials (only when PAYMENT_PROVIDER=meshulam) ──
# Sign up: https://meshulam.co.il
# Dev tests against the sandbox URL; prod flips to the live URL.
# MESHULAM_API_KEY=
# MESHULAM_USER_ID=
# MESHULAM_PAGE_CODE=
# MESHULAM_WEBHOOK_SECRET=
# MESHULAM_BASE_URL=https://sandbox.meshulam.co.il/api/light/server/1.0
# # Production:
# # MESHULAM_BASE_URL=https://meshulam.co.il/api/light/server/1.0

# ═══ Email provider ════════════════════════════════════════════
# Factory switch — pick one of: 'mock' (default, logs to console) |
# 'resend' (real SMTP via Resend).
# EMAIL_PROVIDER=mock
#
# ─── Resend credentials (only when EMAIL_PROVIDER=resend) ──────
# Sign up: https://resend.com (free tier: 100 emails/day).
# The FROM address must live on a domain you've verified in Resend's
# dashboard (DKIM/SPF records). Quick smoke test without a verified
# domain: use `onboarding@resend.dev` as the FROM.
# RESEND_API_KEY=
# EMAIL_FROM=shop@yourdomain.co.il
# EMAIL_FROM_NAME=שורש
#
# Admin recipient for new-order alerts. If unset, the afterChange
# hook on Orders reads site-settings.contact.email instead, so
# this is optional.
# ADMIN_NOTIFICATION_EMAIL=yarit@example.com
